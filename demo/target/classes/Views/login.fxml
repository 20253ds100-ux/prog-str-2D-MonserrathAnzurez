<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="201.0" prefWidth="229.0" spacing="10" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.example.demo.controllers.LoginController">

    <Label text="LOGIN" textFill="#d46ae4">
      <font>
         <Font name="System Bold Italic" size="19.0" />
      </font></Label>
    <TextField fx:id="txtUsuario" prefHeight="25.0" prefWidth="186.0" promptText="Usuario">
      <font>
         <Font name="System Bold Italic" size="12.0" />
      </font></TextField>
    <TextField fx:id="txtCorreo" promptText="Correo">
      <font>
         <Font name="System Bold Italic" size="12.0" />
      </font></TextField>
    <PasswordField fx:id="txtPassword" promptText="Contraseña">
      <font>
         <Font name="System Bold Italic" size="12.0" />
      </font></PasswordField>

    <Button onAction="#handleLogin" text="Iniciar Sesión" textFill="#f87bf2">
      <font>
         <Font name="System Bold Italic" size="11.0" />
      </font></Button>

    <Label fx:id="lblError" textFill="red" />

</VBox>
